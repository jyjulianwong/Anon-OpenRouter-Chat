OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL=anthropic/claude-sonnet-4-5

# Generation parameters (all optional — defaults shown)
LLM_TEMPERATURE=1.0
LLM_MAX_TOKENS=          # unset = model default
LLM_TOP_P=1.0
LLM_TOP_K=               # unset = off
LLM_FREQUENCY_PENALTY=0.0
LLM_PRESENCE_PENALTY=0.0
LLM_REPETITION_PENALTY=1.0
LLM_MIN_P=               # unset = off
LLM_TOP_A=               # unset = off

# Safety — when true, OpenRouter prepends a safety instruction to every prompt
LLM_SAFE_PROMPT=false

# Universal extras
LLM_SEED=               # unset = off (set an integer for deterministic outputs)
LLM_VERBOSITY=          # unset = model default; one of: low, medium, high, xhigh, max
                        # for Claude, this maps to output_config.effort

# Reasoning / extended thinking
# Only sent when at least one is set. Use effort OR max_tokens, not both.
# Supported by thinking-capable models: claude-sonnet-4-5+, gemini-*-thinking, qwq-32b, etc.
LLM_REASONING_EFFORT=        # low | medium | high | max
LLM_REASONING_MAX_TOKENS=    # integer token budget for the thinking block
LLM_REASONING_EXCLUDE=false  # when true, reasoning runs internally but is not returned

# Gemini safety settings (only applied for google/* and gemini/* models)
# Sets all harm categories to BLOCK_NONE. Gemini 2.5+ already defaults to off.
LLM_GEMINI_SAFETY_OFF=true
